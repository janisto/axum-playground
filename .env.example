## Core runtime configuration.
# Cloud Run injects PORT automatically. Keep the default for local development.
PORT=8080
FIREBASE_PROJECT_ID=demo-test-project
APP_ENVIRONMENT=development

# Optional runtime integrations.
GITHUB_TOKEN=

# Local development only. Leave unset on Cloud Run and use service identity there.
GOOGLE_APPLICATION_CREDENTIALS=

# Development/test only. Must use loopback and omit the protocol prefix.
# Example: 127.0.0.1:9099.
FIREBASE_AUTH_EMULATOR_HOST=

# Development/test only. Must use loopback and omit the protocol prefix.
# Example: 127.0.0.1:8080.
FIRESTORE_EMULATOR_HOST=

# Optional Google Cloud project fallbacks for Firestore.
GOOGLE_CLOUD_PROJECT=
GCP_PROJECT=
GCLOUD_PROJECT=
PROJECT_ID=
